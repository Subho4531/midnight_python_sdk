include README.md
include LICENSE
include CONTRIBUTING.md
include CHANGELOG.md
include pyproject.toml
recursive-include midnight_sdk *.py
recursive-include midnight_sdk *.json
recursive-include midnight_sdk *.yaml
recursive-include midnight_sdk *.yml
recursive-include contracts *.compact
recursive-include examples *.py
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .DS_Store
recursive-exclude * .git*
exclude docker-compose.yml
exclude Makefile
exclude *.md
prune docs/
prune tests/
prune .pytest_cache/
prune build/
prune .git/
prune .github/